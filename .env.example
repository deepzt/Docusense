# Copy this file to .env and fill in your values.

# OpenAI API key — enables gpt-4o-mini / gpt-4o / gpt-3.5-turbo
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Gradio authentication (optional)
# If both are set, the web UI will require a login.
GRADIO_USERNAME=admin
GRADIO_PASSWORD=changeme

# OCR support for scanned/image-based PDFs (optional)
# Windows example paths — adjust to your installation
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\poppler\Library\bin
